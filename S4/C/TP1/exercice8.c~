float absolue (float x){
  float res;
  if (x>=0){
    return x;
      }
  else{
    res = -1.0 * x;
    return res;
  }
}

float racine(float x, float p){
  float a = 0.0;
  float b = x;
  float m;
  m = (a+b)/2;
  
  while (absolue(m*m - x) < p){
    b = m;
    a = m;
    m = (a+b)/2; 
  }
  return m;
}

int main(void){
  float res;
  res = racine(16,0.123);
  printf("resulat racine : %f \n",res);
 }
