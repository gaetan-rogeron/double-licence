#include <stdio.h>

float absolue (float x){
  float res;
  if (x>=0){
    return x;
      }
  else{
    res = -1.0 * x;
    return res;
  }
}

float racine(float x, float p){
  float a = 0.0;
  float b = x;
  float m;  
  while (absolue(m*m - x) > p){
   m = (a+b)/2;
   if ( ){
     b = m;
   }
   else {
     a=m;
   }
  }
  return m;
}

int main(void){
  float res;
  res = racine(25,0.0001);
  printf("resulat racine : %f \n",res);
  return 0;
 }
