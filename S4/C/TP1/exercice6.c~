#include <stdio.h>
#include <limits.h>

int somme(int a, int b){
  int result;
  result = a+b;
  if (result > INT_MAX){
    return -1;
  }
  else {
    return result;
  }
}

int fibo_naif(int n){
  int i;
  int u0 = 0;
  int u1 = 1;
  int tmp;
  
  if (n==0){return 0; }
  else if (n==1){ return 1;}
  
  for (i=1;i<=n;i++){
    tmp = somme(u0,u1);
    u0 = u1;
    u1 = tmp;
  }
  return u0;
}

int fibonnacci(int n){
  int i;
  int u0 = 0;
  int u1 = 1;
  int tmp;
  
  if (n==0){return 0;}
  else if (n==1){ return 1;}
  
  for (i=1;i<=n;i++){
    tmp = somme(u0,u1);
    if (tmp > INT_MAX){
      return -1;
    }
    u0 = u1;
    u1 = tmp;
  }
  return u0;
  
}

